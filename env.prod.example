# ─────────────────────────────────────────────────────────────────────────────
# Plantilla de entorno de PRODUCCIÓN. Cópiala a `.env.prod` (gitignored) y rellena
# los secretos:   cp env.prod.example .env.prod
#
# La usan TODOS los servicios de docker-compose.prod.yml (env_file: .env.prod). Los hosts
# de base de datos/redis/minio son los NOMBRES de servicio de compose (red interna), no localhost.
# Genera secretos con:  openssl rand -base64 32
# ─────────────────────────────────────────────────────────────────────────────

# ==== Dominio y TLS (Caddy) ====
# El dominio que compraste. Apunta en tu DNS: A @ , A www y A api → IP del VPS.
DOMAIN=preztia.com
# Correo para los avisos de Let's Encrypt (renovación de certificados).
ACME_EMAIL=admin@preztia.com

# ==== PostgreSQL ====
# Superusuario/dueño del esquema (lo usan la imagen de Postgres y las migraciones).
# CAMBIA POSTGRES_PASSWORD por un secreto fuerte y mantenlo idéntico en DATABASE_URL.
POSTGRES_USER=preztia
POSTGRES_PASSWORD=CAMBIA_ESTE_SECRETO_FUERTE
POSTGRES_DB=preztiaos

# Conexión de migraciones (dueño del esquema). Debe usar el mismo password de arriba.
DATABASE_URL=postgres://preztia:CAMBIA_ESTE_SECRETO_FUERTE@postgres:5432/preztiaos
# Conexión de la APLICACIÓN (rol `app`, sin bypass de RLS). El rol y su password los crea
# docker/initdb/01-init.sql; si cambias el password, edita también ese SQL.
APP_DATABASE_URL=postgres://app:app@postgres:5432/preztiaos
# Conexión del CONTROL-PLANE (rol `platform`, BYPASSRLS). Igual: creado por el initdb.
PLATFORM_DATABASE_URL=postgres://platform:platform@postgres:5432/preztiaos

# ==== Redis ====
REDIS_URL=redis://redis:6379

# ==== Seguridad ====
# Secreto de firma de los JWT. OBLIGATORIO cambiarlo (openssl rand -base64 32).
JWT_SECRET=CAMBIA_ESTE_SECRETO_JWT
# Orígenes permitidos por CORS (la landing llama a api.DOMAIN desde el navegador).
CORS_ORIGIN=https://preztia.com,https://www.preztia.com

# ==== MinIO (documentos KYC, cifrados en reposo) ====
# Credenciales raíz del servidor MinIO. Deben COINCIDIR con MINIO_ACCESS_KEY/SECRET_KEY
# (así la API se autentica contra MinIO).
MINIO_ROOT_USER=preztia-minio
MINIO_ROOT_PASSWORD=CAMBIA_ESTE_SECRETO_MINIO
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=preztia-minio
MINIO_SECRET_KEY=CAMBIA_ESTE_SECRETO_MINIO
MINIO_BUCKET_KYC=kyc-documents
# Clave de cifrado en reposo de documentos KYC (32 bytes en base64). OBLIGATORIA en prod.
# Genérala con: openssl rand -base64 32
KYC_ENCRYPTION_KEY=
KYC_MAX_FILE_MB=25
KYC_MAX_DOCUMENT_ATTEMPTS=3
KYC_MIN_IDENTIFICATION_CONFIDENCE=60

# ==== WhatsApp Cloud API (Meta) ====
WHATSAPP_APP_SECRET=cambia-esto
WHATSAPP_VERIFY_TOKEN=cambia-esto
WHATSAPP_ACCESS_TOKEN=cambia-esto
WHATSAPP_GRAPH_VERSION=v21.0

# ==== IA (Gemini) — la API key se configura por tenant en la BD ====
GEMINI_MODEL=gemini-2.0-flash
GEMINI_VISION_MODEL=gemini-2.5-flash

# ==== Antifraude documental ====
MINHA_RECEITA_URL=https://minhareceita.org
SERPRO_CONSUMER_KEY=
SERPRO_CONSUMER_SECRET=
SERPRO_CONSULTA_CPF_URL=https://gateway.apiserpro.serpro.gov.br/consulta-cpf-trial/v1/cpf

# ==== Pagos (PIX) y conciliación ====
CREDIT_CURRENCY=BRL
PAYMENT_RECEIPT_MAX_AGE_DAYS=7
INTER_API_BASE_URL=https://cdpj.partners.bancointer.com.br
INTER_API_TIMEOUT_MS=10000
RECONCILIATION_MAX_ATTEMPTS=5

# ==== Landing: "pulso del sector" (opcional; hay valores por defecto sensatos) ====
# Fuentes RSS/Atom. Formato: "Etiqueta|url" separadas por ";". Vacío → feeds por defecto (BR).
NEWS_FEEDS=
# Máximo de titulares que sirve el endpoint (por defecto 12).
NEWS_MAX_ITEMS=12
# Timeout por feed en ms (por defecto 8000).
NEWS_FETCH_TIMEOUT_MS=8000
# Hora del refresco diario (cron). Por defecto 06:00 → "0 6 * * *".
NEWS_REFRESH_CRON=0 6 * * *

# ==== Runtime ====
PORT=3000

.expo
**/.expo
coverage
**/coverage

# Control de versiones y metadatos
.git
.github
.vscode
**/.DS_Store

# Secretos y entorno local (nunca deben entrar a la imagen)
.env
.env.*
!.env.example

# Cliente móvil (Expo): no participa en la imagen de la API
apps/mobile/assets
apps/mobile/.expo


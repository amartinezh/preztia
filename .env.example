# Migraciones / dueño del esquema (usuario admin de Postgres)
DATABASE_URL=postgres://preztia:preztia@localhost:5432/preztiaos
# Conexión de la APLICACIÓN (rol sin bypass de RLS)
APP_DATABASE_URL=postgres://app:app@localhost:5432/preztiaos
# Contraseña "quemada" que exige el botón de PURGA de datos de prueba (super admin).
# Vacía = purga deshabilitada (falla cerrado con 403). Úsala solo en entornos de prueba.
PLATFORM_PURGE_PASSWORD=cambia-esto

REDIS_URL=redis://localhost:6379

JWT_SECRET=cambia-esto-en-produccion
# WhatsApp Cloud API (Meta) — webhook de Conversations
WHATSAPP_APP_SECRET=cambia-esto
WHATSAPP_VERIFY_TOKEN=cambia-esto
# Token de acceso y versión de la Graph API para responder mensajes
WHATSAPP_ACCESS_TOKEN=cambia-esto
WHATSAPP_GRAPH_VERSION=v21.0
# Modelo de Gemini (capa gratuita). La API key se configura por tenant en la BD.
GEMINI_MODEL=gemini-2.0-flash
# Modelo multimodal para visión (comprobantes PIX, KYC, foto de negocio). NO usar 'lite': lee mal las imágenes.
GEMINI_VISION_MODEL=gemini-2.5-flash

# MinIO — almacenamiento de documentos KYC (cifrado en reposo)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET_KYC=kyc-documents
# Clave de cifrado en reposo de documentos KYC (32 bytes en base64; cámbiala en producción).
# Genérala con: openssl rand -base64 32
KYC_ENCRYPTION_KEY=
# Tamaño máximo aceptado por documento, en MB (por defecto 25 si se omite).
KYC_MAX_FILE_MB=25
# Intentos de identificación antes de ofrecer revisión manual del analista (por defecto 3).
# Por debajo del máximo se vuelve a pedir; en el máximo se ofrece; por encima se acepta para revisión manual.
KYC_MAX_DOCUMENT_ATTEMPTS=3
# Confianza mínima (0..100) de la IA para considerar el documento "identificado con claridad" (por defecto 60).
KYC_MIN_IDENTIFICATION_CONFIDENCE=60

# Validación documental antifraude (Etapa 3: APIs de uso libre)
# URL de Minha Receita; cámbiala si self-hosteas tu propia instancia.
MINHA_RECEITA_URL=https://minhareceita.org
# Etapa 4 (opcional): Serpro Consulta CPF. Sin credenciales, el pipeline omite
# la verificación de CPF contra la RFB (degradación elegante). El trial es
# gratuito para desarrollo (datos ficticios): https://loja.serpro.gov.br/consultacpf
SERPRO_CONSUMER_KEY=
SERPRO_CONSUMER_SECRET=
# Endpoint de consulta: trial por defecto; cambiar al de producción al contratar.
SERPRO_CONSULTA_CPF_URL=https://gateway.apiserpro.serpro.gov.br/consulta-cpf-trial/v1/cpf

# Pagos (PIX) — recepción de comprobantes y cartera
# Moneda de los créditos que otorga el servidor (Brasil → BRL).
CREDIT_CURRENCY=BRL
# Antigüedad máxima (días) de un comprobante antes de marcarlo sospechoso (por defecto 7).
PAYMENT_RECEIPT_MAX_AGE_DAYS=7

# Conciliación bancaria — Banco Inter (BR). La API key se configura por tenant
# en la tabla tenant_bank_account (no aquí).
INTER_API_BASE_URL=https://cdpj.partners.bancointer.com.br
INTER_API_TIMEOUT_MS=10000
# Intentos de conciliación (banco "not_found") antes de marcar sospecha de fraude (por defecto 5).
RECONCILIATION_MAX_ATTEMPTS=5

# Migraciones / dueño del esquema (usuario admin de Postgres)
DATABASE_URL=postgres://preztia:preztia@localhost:5432/preztiaos
# Conexión de la APLICACIÓN (rol sin bypass de RLS)
APP_DATABASE_URL=postgres://app:app@localhost:5432/preztiaos

REDIS_URL=redis://localhost:6379

JWT_SECRET=cambia-esto-en-produccion
# WhatsApp Cloud API (Meta) — webhook de Conversations
WHATSAPP_APP_SECRET=cambia-esto
WHATSAPP_VERIFY_TOKEN=cambia-esto
# Token de acceso y versión de la Graph API para responder mensajes
WHATSAPP_ACCESS_TOKEN=cambia-esto
WHATSAPP_GRAPH_VERSION=v21.0
# Modelo de Gemini (capa gratuita). La API key se configura por tenant en la BD.
GEMINI_MODEL=gemini-2.0-flash

# MinIO — almacenamiento de documentos KYC (cifrado en reposo)
MINIO_ENDPOINT=http://localhost:9000
MINIO_ACCESS_KEY=minio
MINIO_SECRET_KEY=minio12345
MINIO_BUCKET_KYC=kyc-documents
# Clave de cifrado en reposo de documentos KYC (32 bytes en base64; cámbiala en producción).
# Genérala con: openssl rand -base64 32
KYC_ENCRYPTION_KEY=
# Tamaño máximo aceptado por documento, en MB (por defecto 25 si se omite).
KYC_MAX_FILE_MB=25
# Intentos de identificación antes de ofrecer revisión manual del analista (por defecto 3).
# Por debajo del máximo se vuelve a pedir; en el máximo se ofrece; por encima se acepta para revisión manual.
KYC_MAX_DOCUMENT_ATTEMPTS=3
# Confianza mínima (0..100) de la IA para considerar el documento "identificado con claridad" (por defecto 60).
KYC_MIN_IDENTIFICATION_CONFIDENCE=60
